# Startup Radar — environment variables. Copy to .env and uncomment what you need.
# All values optional. Loaded via startup_radar.config.secrets.Secrets (pydantic-settings).

# Emit structured JSON logs instead of the pretty ConsoleRenderer.
# STARTUP_RADAR_LOG_JSON=1

# CI mode — GH Actions sets this automatically; forces JSON logs.
# CI=1

# Sentry DSN — Sentry SDK wiring is deferred to a later phase; defining the
# variable now so .env stays forward-compatible.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
